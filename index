function addToHistory(historyArr, containerId, name, lookupFn) {
  const proper = name.charAt(0).toUpperCase() + name.slice(1).toLowerCase();
  // Remove if already exists, then add to front
  const idx = historyArr.findIndex(h => h.toLowerCase() === proper.toLowerCase());
  if (idx !== -1) historyArr.splice(idx, 1);
  historyArr.unshift(proper);
  if (historyArr.length > 10) historyArr.pop();
  renderHistory(containerId, historyArr, lookupFn);
}

function renderHistory(containerId, historyArr, lookupFn) {
  const el = document.getElementById(containerId);
  if (!historyArr.length) {
    el.innerHTML = '<span style="font-size:13px;color:#4a6a54;letter-spacing:1px">— NO RECENT SEARCHES —</span>';
    return;
  }
  el.innerHTML = historyArr.map(s =>
    `<button class="suggestion" onclick="${lookupFn}('${s}')">${s}</button>`
  ).join('');
}

