function renderBattle(enemy) {
  const scored = team.map(p => ({
    ...p,
    offMult: getBestMult(p.moves, enemy.types),
    defMult: getDefMult(p.types, enemy.types),
  })).sort((a,b) => b.offMult - a.offMult);

  let html = `
    <div class="enemy-card">
      <img class="enemy-sprite" src="${enemy.sprite}" alt="${enemy.name}"/>
      <div>
        <div class="enemy-vs">VS</div>
        <div class="enemy-name">${enemy.name}</div>
        <div class="type-badges">${enemy.types.map(typeBadge).join('')}</div>
      </div>
    </div>
    <div class="sec-label">PARTY MATCHUP</div>
    <div class="party-results">
  `;

  scored.forEach((p, i) => {
    const isTop = i === 0 && p.offMult > 0;
    const r = getRating(p.offMult);
    const takesSuper = p.defMult >= 2;
    const dmgMoves = p.moves.filter(m => {
      const t = MOVE_TYPES[m.toLowerCase()];
      return t && t !== "—";
    });

    html += `
      <div class="result-card ${isTop?'best':p.offMult===0?'dimmed':''}">
        ${isTop ? `<div class="best-crown">★ BEST</div>` : ''}
        <img class="result-sprite" src="${spriteUrl(p.id)}" alt="${p.name}"/>
        <div class="result-info">
          <div class="result-name-row">
            <span class="result-name">${p.name}</span>
            <span class="result-ptype">${p.types.map(t=>t.toUpperCase()).join('/')}</span>
          </div>
          <div class="result-badges">
            <span class="r-badge" style="color:${r.color};background:${r.color}22;border:1px solid ${r.color}55">
              ${p.offMult>0?p.offMult+'× ':''}${r.label}
            </span>
            ${takesSuper ? `<span class="r-danger">⚠ takes ${p.defMult}× dmg</span>` : ''}
          </div>
          ${dmgMoves.length && p.offMult>0 ? `<div class="r-moves">USE: ${dmgMoves.join(', ')}</div>` : ''}
          ${!getAttackTypes(p.moves).length ? `<div class="r-moves" style="color:#555">NO DAMAGE MOVES</div>` : ''}
        </div>
      </div>
    `;
  });

  html += '</div>';
  document.getElementById('battleResults').innerHTML = html;
}

