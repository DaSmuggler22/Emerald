function buildMemberCard(p, i) {
  const es = editorState[i];

  const typeBadgesHtml = p.types.map(t =>
    `<span class="tbadge" style="background:${TC[t]||'#555'}">${t}</span>`
  ).join('');

  // Swap preview
  let swapPrevHtml = '';
  if (es.swapPreview) {
    const pv = es.swapPreview;
    swapPrevHtml = `
      <div class="swap-preview">
        <img src="${pv.sprite}" alt="${pv.name}" style="width:48px;height:48px;image-rendering:pixelated"/>
        <div>
          <div class="swap-preview-name">${pv.name}</div>
          <div class="swap-preview-types">${pv.types.map(t=>`<span class="tbadge" style="background:${TC[t]||'#555'}">${t}</span>`).join('')}</div>
        </div>
        <button class="swap-confirm" onclick="confirmSwap(${i})">SWAP!</button>
      </div>
    `;
  }

  // Evolution
  let evoHtml = '';
  if (es.evoLoading) {
    evoHtml = `<div class="poke-loading" style="text-align:left;padding:8px 0">LOADING...</div>`;
  } else if (es.evoChain && es.evoChain.length > 1) {
    const curPos = es.evoChain.findIndex(e => e.id === p.id);
    evoHtml = `<div class="evo-chain">` + es.evoChain.map((e, ei) => {
      const isCur  = e.id === p.id;
      const isNext = ei === curPos + 1;
      const cls = isCur ? 'current' : isNext ? 'available' : '';
      const arrow = ei > 0 ? `<span class="evo-arrow">▶</span>` : '';
      return `${arrow}<div class="evo-step ${cls}" onclick="evolveSlot(${i},${ei})">
        <img src="${spriteUrl(e.id)}" alt="${e.name}"/>
        <div class="evo-step-name">${e.name}</div>
      </div>`;
    }).join('') + `</div>
    <div class="evo-hint">TAP GOLD STAGE TO EVOLVE</div>`;
  } else if (es.evoChain && es.evoChain.length === 1) {
    evoHtml = `<div class="evo-none">NO EVOLUTIONS</div>`;
  } else {
    evoHtml = `<button class="evo-load-btn" onclick="loadEvoChain(${i})">▶ LOAD EVOLUTION CHAIN</button>`;
  }

  // Moves
  const movesHtml = p.moves.map((m, mi) => {
    const mt = MOVE_TYPES[m.toLowerCase()];
    const dotColor = mt && mt !== '—' ? (TC[mt]||'#555') : 'rgba(255,255,255,0.1)';
    return `
      <div class="move-row">
        <div class="move-dot" style="background:${dotColor}"></div>
        <input class="move-input" value="${m}" placeholder="Move name"
          onchange="updateMove(${i},${mi},this.value)"
          autocorrect="off" autocapitalize="words" spellcheck="false"/>
        <button class="move-remove" onclick="removeMove(${i},${mi})">✕</button>
      </div>
    `;
  }).join('');

  return `
    <div class="member-card ${es.open?'open':''}" id="mc-${i}">
      <div class="member-header" onclick="toggleMember(${i})">
        <img class="member-sprite" src="${spriteUrl(p.id)}" alt="${p.name}"/>
        <div class="member-info">
          <div class="member-name">${p.name}</div>
          <div class="member-types">${typeBadgesHtml}</div>
        </div>
        <div class="member-chevron ${es.open?'open':''}">▼</div>
      </div>
      <div class="member-body ${es.open?'open':''}">

        <div class="ed-section">
          <div class="ed-label">SWAP POKÉMON</div>
          <div class="swap-row">
            <input class="poke-input" placeholder="Search..." value="${es.swapInput}"
              id="swap-input-${i}"
              oninput="editorState[${i}].swapInput=this.value"
              onkeydown="if(event.key==='Enter')searchSwap(${i})"
              autocorrect="off" autocapitalize="off" spellcheck="false"/>
            <button class="poke-btn-gray" onclick="searchSwap(${i})">${es.swapLoading?'...':'FIND'}</button>
          </div>
          ${es.swapError ? `<div class="poke-error">${es.swapError}</div>` : ''}
          ${swapPrevHtml}
        </div>

        <div class="ed-section">
          <div class="ed-label">EVOLUTION CHAIN</div>
          ${evoHtml}
        </div>

        <div class="ed-section">
          <div class="ed-label">MOVES (${p.moves.length}/4)</div>
          <div class="moves-list">${movesHtml}</div>
          ${p.moves.length < 4 ? `<button class="add-move-btn" onclick="addMove(${i})">+ ADD MOVE</button>` : ''}
        </div>

      </div>
    </div>
  `;
}

function toggleMember(i) {
  editorState[i].open = !editorState[i].open;
  renderTeamEditor();
}

// Swap
async function searchSwap(i) {
  const es = editorState[i];
  const inp = document.getElementById(`swap-input-${i}`);
  const val = inp ? inp.value.trim() : es.swapInput.trim();
  if (!val) return;
  es.swapInput = val;
  es.swapLoading = true; es.swapError = ''; es.swapPreview = null;
  renderTeamEditor();
  try {
    es.swapPreview = await fetchPoke(val);
  } catch {
    es.swapError = `"${val}" NOT FOUND`;
  }
  es.swapLoading = false;
  renderTeamEditor();
}

function confirmSwap(i) {
  const pv = editorState[i].swapPreview;
  if (!pv) return;
  team[i] = {
    name: pv.name.charAt(0).toUpperCase() + pv.name.slice(1),
    id: pv.id, types: pv.types,
    moves: ["—"], color: TC[pv.types[0]] || "#888",
  };
  editorState[i] = { open:true, swapInput:"", swapPreview:null, swapError:"", swapLoading:false, evoChain:null, evoLoading:false };
  renderTeamEditor();
}

// Evolution
async function loadEvoChain(i) {
  editorState[i].evoLoading = true;
  renderTeamEditor();
  try {
    const specRes  = await fetch(`https://pokeapi.co/api/v2/pokemon-species/${team[i].id}`);
    const specData = await specRes.json();
    const evoRes   = await fetch(specData.evolution_chain.url);
    const evoData  = await evoRes.json();
    const chain = [];
    async function walk(node) {
      const r = await fetch(`https://pokeapi.co/api/v2/pokemon/${node.species.name}`);
      const d = await r.json();
      chain.push({ name: node.species.name, id: d.id });
      for (const nx of node.evolves_to) await walk(nx);
    }
    await walk(evoData.chain);
    editorState[i].evoChain = chain;
  } catch { editorState[i].evoChain = []; }
  editorState[i].evoLoading = false;
  renderTeamEditor();
}

async function evolveSlot(slotIdx, evoIdx) {
  const chain  = editorState[slotIdx].evoChain;
  const curPos = chain.findIndex(e => e.id === team[slotIdx].id);
  if (evoIdx !== curPos + 1) return;
  const target = chain[evoIdx];
  try {
    const r = await fetch(`https://pokeapi.co/api/v2/pokemon/${target.id}`);
    const d = await r.json();
    const newTypes = d.types.map(t=>t.type.name);
    team[slotIdx].name  = target.name.charAt(0).toUpperCase() + target.name.slice(1);
    team[slotIdx].id    = target.id;
    team[slotIdx].types = newTypes;
    team[slotIdx].color = TC[newTypes[0]] || '#888';
  } catch {}
  renderTeamEditor();
}

// Moves
function updateMove(slotIdx, moveIdx, val) {
  team[slotIdx].moves[moveIdx] = val.trim() || '—';
  renderTeamEditor();
}
function removeMove(slotIdx, moveIdx) {
  team[slotIdx].moves.splice(moveIdx, 1);
  renderTeamEditor();
}
function addMove(slotIdx) {
  if (team[slotIdx].moves.length < 4) {
    team[slotIdx].moves.push('');
    renderTeamEditor();
    setTimeout(() => {
      const card = document.getElementById(`mc-${slotIdx}`);
      if (card) { const ins = card.querySelectorAll('.move-input'); if(ins.length) ins[ins.length-1].focus(); }
    }, 50);
  }
}
</script>

</body>
</html>
