async function fetchAndRenderCatch(name) {
  const errEl = document.getElementById('catchError');
  const resEl = document.getElementById('catchResults');
  errEl.style.display = 'none';
  resEl.innerHTML = `<div class="poke-loading">ANALYZING TEAM...</div>`;
  try {
    const candidate = await fetchPoke(name);
    addToHistory(catchHistory, 'catchSuggs', candidate.name, 'quickCatch');
    renderCatchAnalysis(candidate);
  } catch {
    resEl.innerHTML = '';
    errEl.textContent = `"${name}" NOT FOUND — CHECK SPELLING!`;
    errEl.style.display = 'block';
  }
}

function renderCatchAnalysis(candidate) {
  const currentScore  = teamCoverageScore(team);
  const currentWeaks  = teamWeaknesses(team);
  const currentUncov  = teamUncoveredTypes(team);

  // Simulate replacing each team slot with candidate
  const improvements = team.map((member, i) => {
    const newTeam = team.map((p, j) => j === i ? { ...candidate, moves: candidate.types.map(t => t) } : p);
    // Give candidate credit for STAB moves from its types
    const fakeMoves = candidate.types.flatMap(t => {
      const moveMap = { fire:["ember"], water:["water gun"], grass:["absorb"], electric:["thundershock"],
        psychic:["confusion"], fighting:["low kick"], rock:["rock throw"], ground:["mud slap"],
        flying:["gust"], ghost:["shadow ball"], ice:["ice beam"], dragon:["dragon claw"],
        dark:["bite"], steel:["metal claw"], bug:["fury cutter"], poison:["poison sting"],
        normal:["tackle"], fairy:["dazzling gleam"] };
      return moveMap[t] || [];
    });
    const fakeCandidate = { ...candidate, moves: fakeMoves };
    const testTeam = team.map((p, j) => j === i ? fakeCandidate : p);
    const newScore = teamCoverageScore(testTeam);
    const newWeaks = teamWeaknesses(testTeam);
    const scoreDelta = newScore - currentScore;
    const weakDelta  = currentWeaks.length - newWeaks.length;
    return { member, index: i, scoreDelta, weakDelta, newScore, newWeaks };
  }).sort((a, b) => (b.scoreDelta + b.weakDelta) - (a.scoreDelta + a.weakDelta));

  const best = improvements[0];
  const netGain = best.scoreDelta + best.weakDelta;

  // Determine verdict
  let verdict, verdictClass, reason;
  const newTypeCoverage = candidate.types.some(t => !team.some(p => p.types.includes(t)));
  const coversWeakness = candidate.types.some(t => !currentWeaks.includes(t) === false || currentUncov.includes(t));

  if (netGain >= 2 || best.scoreDelta >= 2) {
    verdict = "CATCH IT!"; verdictClass = "verdict-yes";
    reason = `${candidate.name.charAt(0).toUpperCase()+candidate.name.slice(1)} covers ${best.scoreDelta} new type(s) your team is missing. Solid upgrade for coverage.`;
  } else if (netGain >= 1 || currentUncov.some(t => candidate.types.some(at => getEff(at,[t])>=2))) {
    verdict = "WORTH IT"; verdictClass = "verdict-maybe";
    reason = `${candidate.name.charAt(0).toUpperCase()+candidate.name.slice(1)} provides some new coverage and could fill a gap. Consider it if you need that typing.`;
  } else if (newTypeCoverage) {
    verdict = "MAYBE"; verdictClass = "verdict-maybe";
    reason = `${candidate.name.charAt(0).toUpperCase()+candidate.name.slice(1)} brings a new type to the team but doesn't dramatically improve coverage right now.`;
  } else {
    verdict = "SKIP IT"; verdictClass = "verdict-no";
    reason = `Your team already covers what ${candidate.name.charAt(0).toUpperCase()+candidate.name.slice(1)} offers. No significant coverage improvement.`;
  }

  // Types candidate covers that team currently misses
  const newCoverage = currentUncov.filter(t => {
    const fakeMoves = candidate.types.flatMap(ct => {
      const mm = {fire:["ember"],water:["water gun"],grass:["absorb"],electric:["thundershock"],psychic:["confusion"],fighting:["low kick"],rock:["rock throw"],ground:["mud slap"],flying:["gust"],ghost:["shadow ball"],ice:["ice beam"],dragon:["dragon claw"],dark:["bite"],steel:["metal claw"],bug:["fury cutter"],poison:["poison sting"],normal:["tackle"],fairy:["dazzling gleam"]};
      return mm[ct] || [];
    });
    return getBestMult(fakeMoves, [t]) >= 2;
  });

  let html = `
    <div class="catch-result">
      <div class="catch-header">
        <img class="catch-sprite" src="${candidate.sprite}" alt="${candidate.name}"/>
        <div>
          <div class="catch-pname">${candidate.name}</div>
          <div class="type-badges" style="margin:4px 0">${candidate.types.map(typeBadge).join('')}</div>
          <span class="catch-verdict ${verdictClass}">${verdict}</span>
        </div>
      </div>
      <div class="catch-body">
        <div class="catch-reason">${reason}</div>
  `;

  if (newCoverage.length > 0) {
    html += `
      <div class="sec-label" style="margin-bottom:8px">NEW TYPE COVERAGE</div>
      <div style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:12px">
        ${newCoverage.map(t => `<span class="tbadge" style="background:${TC[t]||'#555'}">${t}</span>`).join('')}
      </div>
    `;
  }

  html += `<div class="sec-label" style="margin-bottom:8px">SWAP SUGGESTIONS</div>`;

  improvements.slice(0, 3).forEach((imp, i) => {
    const isRec = i === 0 && netGain > 0;
    const delta = imp.scoreDelta + imp.weakDelta;
    const deltaStr = delta > 0 ? `+${delta} coverage` : delta === 0 ? 'No change' : `${delta} coverage`;
    html += `
      <div class="swap-suggestion ${isRec?'recommended':''}">
        <img class="swap-sug-sprite" src="${spriteUrl(imp.member.id)}" alt="${imp.member.name}"/>
        <div class="swap-sug-info">
          <div class="swap-sug-name">Replace ${imp.member.name}</div>
          <div class="swap-sug-reason">${deltaStr} · ${imp.newScore}/18 types covered</div>
        </div>
        ${isRec ? `<div class="swap-sug-label">★ BEST<br>SWAP</div>` : ''}
      </div>
    `;
  });

  // Current team weaknesses
  if (currentWeaks.length) {
    html += `
      <div class="sec-label" style="margin-top:12px;margin-bottom:8px">TEAM WEAKNESSES</div>
      <div style="display:flex;flex-wrap:wrap;gap:4px">
        ${currentWeaks.map(t=>`<span class="tbadge" style="background:${TC[t]||'#555'}">${t}</span>`).join('')}
      </div>
    `;
  }

  html += '</div></div>';
  document.getElementById('catchResults').innerHTML = html;
}

