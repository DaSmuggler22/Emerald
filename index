// ─── HELPERS ─────────────────────────────────────────────────
function getEff(at, defTypes) {
  let m = 1;
  defTypes.forEach(dt => m *= ((TYPE_CHART[at]||{})[dt] ?? 1));
  return m;
}
function getAttackTypes(moves) {
  const s = new Set();
  moves.forEach(m => { const t = MOVE_TYPES[m.toLowerCase()]; if (t && t !== "—") s.add(t); });
  return [...s];
}
function getBestMult(moves, defTypes) {
  const ats = getAttackTypes(moves);
  if (!ats.length) return 0;
  return Math.max(...ats.map(at => getEff(at, defTypes)));
}
function getDefMult(pTypes, atkTypes) {
  let m = 1;
  atkTypes.forEach(at => pTypes.forEach(dt => m *= ((TYPE_CHART[at]||{})[dt] ?? 1)));
  return m;
}
function getRating(mult) {
  if (mult === 0)  return { label:"NO EFFECT",        color:"#555555" };
  if (mult >= 4)   return { label:"4× SUPER!",         color:"#ff4444" };
  if (mult >= 2)   return { label:"2× SUPER",          color:"#00c864" };
  if (mult === 1)  return { label:"NEUTRAL",           color:"#6b7280" };
  return              { label:"NOT VERY",           color:"#ff9900" };
}
function typeBadge(t) {
  return `<span class="tbadge" style="background:${TC[t]||'#555'}">${t}</span>`;
}
function spriteUrl(id) {
  return `https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/${id}.png`;
}
async function fetchPoke(name) {
  const res = await fetch(`https://pokeapi.co/api/v2/pokemon/${name.trim().toLowerCase()}`);
  if (!res.ok) throw new Error();
  const d = await res.json();
  return { name:d.name, id:d.id, types:d.types.map(t=>t.type.name), sprite:d.sprites.front_default };
}

// ─── TEAM COVERAGE SCORE ─────────────────────────────────────
function teamCoverageScore(members) {
  // How many of 18 types have at least 2× coverage
  let covered = 0;
  ALL_TYPES.forEach(t => {
    const hasCoverage = members.some(p => getBestMult(p.moves, [t]) >= 2);
    if (hasCoverage) covered++;
  });
  return covered;
}

function teamWeaknesses(members) {
  // Types that ALL members are weak to (no one resists)
  return ALL_TYPES.filter(t =>
    members.every(p => getDefMult(p.types, [t]) >= 2)
  );
}

function teamUncoveredTypes(members) {
  return ALL_TYPES.filter(t =>
    !members.some(p => getBestMult(p.moves, [t]) >= 2)
  );
}

